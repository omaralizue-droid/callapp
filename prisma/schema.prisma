datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}
enum Role {
  OWNER
  ADMIN
  QA_MANAGER
  MANAGER
  QA
  AGENT
  VIEWER
}

enum CallStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum UsageType {
  CALL
  STORAGE
  AI_REQUEST
  AGENT
  REPORT
}

enum NotificationType {
  CALL_PROCESSED
  QA_COMPLETED
  SYSTEM_ALERT
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  supabaseId     String?   @unique // Links to Supabase Auth user ID
  firstName      String?
  lastName       String?
  avatarUrl      String?
  role           Role      @default(AGENT)
  
  // Tenancy relations
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamId         String?
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Call & QA relations
  calls          Call[]        @relation("AgentCalls")
  qaReports      QAReport[]    @relation("ReviewerReports")
  
  // Audits & Utilities
  notifications  Notification[]
  activityLogs   ActivityLog[]
  
  // Soft Delete & Timestamps
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([teamId])
  @@index([email])
  @@map("users")
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logoUrl   String?

  // White Label Branding
  brandName              String?  @map("brand_name")               // Replaces "CallPilot.AI" in UI
  brandLogoUrl           String?  @map("brand_logo_url")           // Custom logo image URL
  brandColor             String?  @map("brand_color")              // Primary hex e.g. "#4f46e5"
  brandColorDark         String?  @map("brand_color_dark")         // Darker variant for gradients
  emailFromName          String?  @map("email_from_name")          // "Acme Support" in email From
  emailFooterText        String?  @map("email_footer_text")        // Custom footer in notification emails
  customDomain           String?  @map("custom_domain")            // e.g. "app.mycompany.com"
  customDomainVerified   Boolean  @default(false) @map("custom_domain_verified")

  // Relations
  users     User[]
  teams     Team[]
  calls     Call[]
  setting   Setting?

  // Subscription fields
  stripeCustomerId       String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map("stripe_subscription_id")
  stripePriceId          String?   @map("stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")
  stripeCancelAtPeriodEnd Boolean   @default(false) @map("stripe_cancel_at_period_end")
  planName               String    @default("Starter") @map("plan_name")
  planStatus             String    @default("TRIAL") @map("plan_status") // ACTIVE, TRIAL, CANCELED, EXPIRED, PAST_DUE
  trialEndsAt            DateTime? @map("trial_ends_at")
  callLimit              Int       @default(100) @map("call_limit")
  usedCalls              Int       @default(0) @map("used_calls")

  // Extended usage tracking fields
  storageLimit           BigInt    @default(5368709120) @map("storage_limit")     // 5 GB default in bytes
  storageUsedBytes       BigInt    @default(0) @map("storage_used_bytes")
  aiRequestsLimit        Int       @default(100) @map("ai_requests_limit")
  aiRequestsUsed         Int       @default(0) @map("ai_requests_used")
  agentsLimit            Int       @default(5) @map("agents_limit")
  agentsUsed             Int       @default(0) @map("agents_used")
  reportsLimit           Int       @default(50) @map("reports_limit")
  reportsUsed            Int       @default(0) @map("reports_used")
  usageResetAt           DateTime? @map("usage_reset_at")

  paymentHistories       PaymentHistory[]
  usageLogs              UsageLog[]
  qaScorecards           QAScorecard[]
  invitations            OrganizationInvitation[]
  apiKeys                ApiKey[]
  integrations           Integration[]

  // Soft Delete & Timestamps
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@map("organizations")
}

model Team {
  id             String       @id @default(uuid())
  name           String
  description    String?
  
  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  calls          Call[]
  
  qaScorecardId  String?      @map("qa_scorecard_id")
  qaScorecard    QAScorecard? @relation("TeamScorecard", fields: [qaScorecardId], references: [id], onDelete: SetNull)

  // Soft Delete & Timestamps
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("teams")
}

model Call {
  id             String        @id @default(uuid())
  title          String?
  filename       String
  fileUrl        String
  duration       Float         @default(0.0) // duration in seconds
  fileSize       Int           @default(0)   // file size in bytes
  status         CallStatus    @default(PENDING)
  
  // Customer Metadata
  customerId     String?       @map("customer_id")
  customerName   String?       @map("customer_name")
  
  // Relations
  agentId        String?
  agent          User?         @relation("AgentCalls", fields: [agentId], references: [id], onDelete: SetNull)
  teamId         String?
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  qaScorecardId  String?       @map("qa_scorecard_id")
  qaScorecard    QAScorecard?  @relation(fields: [qaScorecardId], references: [id], onDelete: SetNull)

  // Analysis, QA and CRM relations
  analysis       CallAnalysis?
  qaReports      QAReport[]
  crmNote        CRMNote?

  // Soft Delete & Timestamps
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([agentId])
  @@index([teamId])
  @@index([status])
  @@map("calls")
}

model QAScorecard {
  id             String         @id @default(uuid())
  name           String
  description    String?
  version        Int            @default(1)
  isArchived     Boolean        @default(false) @map("is_archived")
  
  // Custom items structure
  complianceItems Json          // Structure: string[]
  softSkillItems  Json          // Structure: string[]
  
  // Tenancy
  organizationId String         @map("organization_id")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Scorecard assignments to teams
  teams          Team[]         @relation("TeamScorecard")
  
  // Version history linkage
  parentId       String?        @map("parent_id")
  parent         QAScorecard?   @relation("ScorecardVersions", fields: [parentId], references: [id], onDelete: SetNull)
  versions       QAScorecard[]  @relation("ScorecardVersions")

  // Calls audited with this scorecard
  calls          Call[]

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("qa_scorecards")
}

model CallAnalysis {
  id               String    @id @default(uuid())
  callId           String    @unique @map("call_id")
  call             Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  
  summary          String
  transcript       Json      // Structure: [{ speaker: string, text: string, start: number, end: number, sentiment: string }]
  sentimentOverall Sentiment @default(NEUTRAL) @map("sentiment_overall")
  sentimentScore   Float     @default(0.0) @map("sentiment_score") // Score between -1.0 and 1.0
  coachingTips     Json      // Structure: string[]
  strengths        Json      // Structure: string[]
  improvements     Json      // Structure: string[]
  aiCoachReport    Json?     @map("ai_coach_report")

  // Soft Delete & Timestamps
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("call_analyses")
}

model QAReport {
  id             String    @id @default(uuid())
  callId         String    @map("call_id")
  call           Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  
  reviewerId     String?   @map("reviewer_id")
  reviewer       User?     @relation("ReviewerReports", fields: [reviewerId], references: [id], onDelete: SetNull)
  
  score          Int       @default(0) // Scale 0-100
  checklist      Json      // Structure: { compliance: { score: number, items: [] }, softSkills: { score: number, items: [] } }
  feedback       String?

  // Soft Delete & Timestamps
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([callId])
  @@index([reviewerId])
  @@map("qa_reports")
}

model CRMNote {
  id                String    @id @default(uuid())
  callId            String    @unique @map("call_id")
  call              Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  
  summary           String
  keyPoints         Json      // Structure: string[]
  actionItems       Json      // Structure: string[]
  
  // New Structured Fields
  customerName      String?
  agentName         String?
  callPurpose       String?
  issue             String?
  resolution        String?
  followUp          String?
  productsMentioned Json?     // Structure: string[]
  callDuration      Float?
  importantNotes    String?
  
  exported          Boolean   @default(false)
  exportedAt        DateTime? @map("exported_at")

  // Soft Delete & Timestamps
  isDeleted         Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("crm_notes")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  type      NotificationType @default(SYSTEM_ALERT)
  isRead    Boolean          @default(false) @map("is_read")

  // Soft Delete & Timestamps
  isDeleted Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action    String
  details   String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("activity_logs")
}

model Setting {
  id                     String       @id @default(uuid())
  organizationId         String       @unique @map("organization_id")
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  qaRubric               Json         // Structure of customizable quality guidelines
  crmIntegrationSettings Json?        // Settings for CRMs like HubSpot, Salesforce
  notificationsConfig    Json         // Email notification preferences

  // Soft Delete & Timestamps
  isDeleted              Boolean      @default(false)
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  @@map("settings")
}

model PaymentHistory {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  stripeInvoiceId String      @unique @map("stripe_invoice_id")
  amount          Float
  status          String       // PAID, FAILED, PENDING
  planName        String       @map("plan_name")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([organizationId])
  @@map("payment_histories")
}

model UsageLog {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type           UsageType
  amount         Int          @default(1)
  description    String?

  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([type])
  @@map("usage_logs")
}

model BackgroundJob {
  id             String    @id @default(uuid())
  callId         String    @unique @map("call_id")
  status         String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("background_jobs")
}

model OrganizationInvitation {
  id             String       @id @default(uuid())
  email          String
  role           Role         @default(AGENT)
  token          String       @unique
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Status tracking
  isAccepted     Boolean      @default(false) @map("is_accepted")
  isRevoked      Boolean      @default(false) @map("is_revoked")
  expiresAt      DateTime     @map("expires_at")
  
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([token])
  @@index([email])
  @@map("organization_invitations")
}


model ApiKey {
  id             String       @id @default(uuid())
  name           String
  keyPrefix      String       @map("key_prefix")   // First 10 chars shown to user e.g. "cp_live_ab"
  keyHash        String       @unique @map("key_hash") // SHA-256 hash — plaintext never stored

  // Permissions
  scopes         String[]     // e.g. ["calls:read", "qa:read", "upload:write"]
  rateLimitRpm   Int          @default(60) @map("rate_limit_rpm")

  // Status
  isRevoked      Boolean      @default(false) @map("is_revoked")
  lastUsedAt     DateTime?    @map("last_used_at")
  expiresAt      DateTime?    @map("expires_at")

  // Tenancy
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?      @map("created_by_id")

  // Audit logs
  auditLogs      ApiKeyAuditLog[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([keyHash])
  @@map("api_keys")
}

model ApiKeyAuditLog {
  id             String   @id @default(uuid())
  apiKeyId       String   @map("api_key_id")
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  action         String   // CREATED | REVOKED | REGENERATED | USED | RATE_LIMITED | VIEWED
  performedById  String?  @map("performed_by_id")
  ipAddress      String?  @map("ip_address")
  details        String?

  createdAt      DateTime @default(now()) @map("created_at")

  @@index([apiKeyId])
  @@map("api_key_audit_logs")
}

model Integration {
  id             String       @id @default(uuid())
  provider       String       // HUBSPOT | SALESFORCE | SLACK | TEAMS | ZAPIER | WEBHOOK
  name           String       // User-defined label e.g. "Slack #qa-alerts"
  isEnabled      Boolean      @default(false) @map("is_enabled")

  // Flexible JSON config — stores provider-specific fields
  // e.g. { webhookUrl, apiKey, oauthToken, channelId, instanceUrl }
  config         Json         @default("{}")

  // Connection status
  status         String       @default("DISCONNECTED") // CONNECTED | DISCONNECTED | ERROR | PENDING
  lastSyncAt     DateTime?    @map("last_sync_at")
  errorMessage   String?      @map("error_message")

  // Tenancy
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?      @map("created_by_id")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([provider])
  @@map("integrations")
}
